<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1751163892826-1" author="jemil-dilan">
        <createTable tableName="t_class">
            <column autoIncrement="true" name="c_class_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_t_class"/>
            </column>
            <column name="c_class_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="c_academic_year" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="c_teacher_id" type="UUID"/>
            <column name="c_class_capacity" type="INT"/>
            <column name="c_available_seats" type="INT"/>
            <column name="c_section" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1751163892826-2" author="jemil-dilan">
        <addUniqueConstraint columnNames="c_class_name" constraintName="uc_t_class_c_class_name" tableName="t_class"/>
    </changeSet>
    <changeSet id="1751163892826-3" author="jemil-dilan">
        <addUniqueConstraint columnNames="c_teacher_id" constraintName="uc_t_class_c_teacher" tableName="t_class"/>
    </changeSet>
    <changeSet id="1751163892826-4" author="jemil-dilan">
        <addForeignKeyConstraint baseColumnNames="c_teacher_id" baseTableName="t_class"
                                 constraintName="FK_T_CLASS_ON_C_TEACHER" referencedColumnNames="c_staff_id"
                                 referencedTableName="t_teachers"/>
    </changeSet>

</databaseChangeLog>