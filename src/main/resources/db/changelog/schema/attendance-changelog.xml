<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1751163360126-1" author="jemil-dilan">
        <createTable tableName="t_attendance">
            <column autoIncrement="true" name="c_attendance_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_t_attendance"/>
            </column>
            <column name="c_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="c_status" type="SMALLINT">
                <constraints nullable="false"/>
            </column>
            <column name="c_student_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1751163360126-2" author="jemil-dilan">
        <addUniqueConstraint columnNames="c_student_id" constraintName="uc_t_attendance_c_student"
                             tableName="t_attendance"/>
    </changeSet>
    <changeSet id="1751163360126-3" author="jemil-dilan">
        <addForeignKeyConstraint baseColumnNames="c_student_id" baseTableName="t_attendance"
                                 constraintName="FK_T_ATTENDANCE_ON_C_STUDENT" referencedColumnNames="c_student_id"
                                 referencedTableName="t_students"/>
    </changeSet>

</databaseChangeLog>