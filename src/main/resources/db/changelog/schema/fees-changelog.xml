<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1751162999167-1" author="jemil-dilan">
        <createTable tableName="t_fees_&amp;_payments">
            <column autoIncrement="true" name="c_payment_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_t_fees_&amp;_payments"/>
            </column>
            <column name="c_amount_paid" type="DECIMAL">
                <constraints nullable="false"/>
            </column>
            <column name="c_payment_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="c_staff_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1751162999167-2" author="jemil-dilan">
        <addUniqueConstraint columnNames="c_staff_id" constraintName="uc_t_fees_&amp;_payments_c_staff"
                             tableName="t_fees_&amp;_payments"/>
    </changeSet>

</databaseChangeLog>