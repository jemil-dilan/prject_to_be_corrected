<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1751163204975-1" author="jemil-dilan">
        <createTable tableName="t_bus">
            <column autoIncrement="true" name="c_bus_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_t_bus"/>
            </column>
            <column name="c_bus_model" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="c_make_year" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="c_plate_number" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="c_bus_capacity" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="c_route_info" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="c_driver_licence_number" type="UUID"/>
        </createTable>
    </changeSet>
    <changeSet id="1751163204975-2" author="jemil-dilan">
        <addUniqueConstraint columnNames="c_driver_licence_number" constraintName="uc_t_bus_c_driver_licence_number"
                             tableName="t_bus"/>
    </changeSet>
    <changeSet id="1751163204975-3" author="jemil-dilan">
        <addUniqueConstraint columnNames="c_plate_number" constraintName="uc_t_bus_c_plate_number" tableName="t_bus"/>
    </changeSet>
    <changeSet id="1751163204975-4" author="jemil-dilan">
        <addForeignKeyConstraint baseColumnNames="c_driver_licence_number" baseTableName="t_bus"
                                 constraintName="FK_T_BUS_ON_C_DRIVER_LICENCE_NUMBER" referencedColumnNames="c_staff_id"
                                 referencedTableName="c_bus_driver"/>
    </changeSet>

</databaseChangeLog>